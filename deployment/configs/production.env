# PixelCore 生产环境配置

## 基础配置
NAMESPACE=pixelcore
ENVIRONMENT=production

## 数据库配置
POSTGRES_HOST=postgres-ha-service
POSTGRES_PORT=5432
POSTGRES_DB=pixelcore
POSTGRES_USER=pixelcore
# POSTGRES_PASSWORD=<从Secret获取>

## Redis配置
REDIS_HOST=redis-ha-service
REDIS_PORT=6379
# REDIS_PASSWORD=<从Secret获取>

## 应用配置
BACKEND_REPLICAS=5
FRONTEND_REPLICAS=3
LOG_LEVEL=info

## 监控配置
PROMETHEUS_NAMESPACE=monitoring
GRAFANA_NAMESPACE=monitoring

## 备份配置
VELERO_NAMESPACE=velero
BACKUP_BUCKET=pixelcore-backups
BACKUP_REGION=us-west-2

## 告警配置
SLACK_WEBHOOK_URL=<配置Slack Webhook>
ALERT_EMAIL=alerts@example.com

## 域名配置
DOMAIN=pixelcore.example.com
SSL_CERT_ISSUER=letsencrypt-prod

## 资源限制
BACKEND_CPU_REQUEST=500m
BACKEND_CPU_LIMIT=2000m
BACKEND_MEMORY_REQUEST=512Mi
BACKEND_MEMORY_LIMIT=2Gi

FRONTEND_CPU_REQUEST=250m
FRONTEND_CPU_LIMIT=1000m
FRONTEND_MEMORY_REQUEST=256Mi
FRONTEND_MEMORY_LIMIT=1Gi

## HPA配置
BACKEND_MIN_REPLICAS=3
BACKEND_MAX_REPLICAS=10
BACKEND_TARGET_CPU=70

FRONTEND_MIN_REPLICAS=2
FRONTEND_MAX_REPLICAS=5
FRONTEND_TARGET_CPU=70

## 安全配置
ENABLE_NETWORK_POLICIES=true
ENABLE_POD_SECURITY=true
ENABLE_MTLS=true

## 功能开关
ENABLE_CHAOS_ENGINEERING=false
ENABLE_CANARY_DEPLOYMENT=false
ENABLE_BLUE_GREEN_DEPLOYMENT=false
